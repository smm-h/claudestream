{
  "targets": [
    "pypi",
    "npm"
  ],
  "pipelines": {
    "pypi": {
      "type": "pypi",
      "local": false
    },
    "npm": {
      "type": "npm",
      "local": false,
      "provenance": true
    }
  },
  "private": false,
  "push_timeout": 120,
  "check_timeout": 300,
  "coverage_unit": "commit"
}
