  "groups": {
    "agent": {
      "name": "agent",
      "help": "Manage and run agents defined in .agent.json files. Agent definitions declare a model, prompt template, allowed tools with input schemas, sandbox permissions, and budget limits (cost, turns, tokens). Use subcommands to validate configurations, run agents against prompts, and inspect metadata.",
      "commands": {
        "run": {
          "name": "run",
          "help": "Load an agent definition and run it with the given prompt. Accepts a path to a .agent.json file or a bare agent name (resolved from .claudestream/agents/). The definition specifies the model, a prompt template with {variable} placeholders, tool schemas, sandbox policy, and budget constraints. Use --var key=value to substitute template variables. Use --model to override the model declared in the definition.",
          "flags": [
            {
              "name": "var",
              "type": "str",
              "help": "Variable in key=value format (repeatable)",
              "default": [],
              "repeatable": true
            },
            {
              "name": "model",
              "type": "str",
              "help": "Model override",
              "short": "m",
              "default": ""
            },
            {
              "name": "profile",
              "type": "str",
              "help": "claudewheel profile to use"
            },
            {
              "name": "cwd",
              "type": "str",
              "help": "Working directory",
              "default": ""
            },
            {
              "name": "footer",
              "type": "bool",
              "help": "Show cost and timing on stderr",
              "default": true,
              "negatable": true
            },
            {
              "name": "no-color",
              "type": "bool",
              "help": "Disable colored output",
              "default": false,
              "negatable": true
            }
          ],
          "args": [
            {
              "name": "prompt",
              "help": "User message to send to the agent"
            },
            {
              "name": "definition",
              "help": "Agent name or path to .agent.json file"
            }
          ]
        },
        "list": {
          "name": "list",
          "help": "List available agents from .claudestream/agents/. Scans the agents directory in the working directory (or the directory specified by --cwd) and prints a table with each agent's name, schema version, and description. Use this to discover which agents are configured before running one with 'agent run'.",
          "flags": [
            {
              "name": "cwd",
              "type": "str",
              "help": "Working directory",
              "default": ""
            }
          ]
        },
        "info": {
          "name": "info",
          "help": "Display agent definition details for a given agent name or path. Loads the .agent.json file, parses it, and prints every configured field: name, version, description, model, budget limits, sandbox policy, tool schemas, MCP server config, and stream options. Use this to inspect an agent's full configuration before invoking it.",
          "args": [
            {
              "name": "name",
              "help": "Agent name or path"
            }
          ]
        },
        "validate": {
          "name": "validate",
          "help": "Validate an agent definition by loading and checking its .agent.json file for structural and semantic correctness. Verifies that budget values are non-negative, the prompt template is non-empty, tool schemas are well-formed, and required fields are present. Reports specific errors on failure or prints a success confirmation.",
          "args": [
            {
              "name": "name",
              "help": "Agent name or path"
            }
          ]
        }
      }
    }
  }
