  "groups": {
    "agent": {
      "name": "agent",
      "help": "Manage and run agents defined in .agent.json files. Agent definitions declare a model, prompt template, allowed tools with input schemas, sandbox permissions, and budget limits (cost, turns, tokens). Use subcommands to validate configurations, run agents against prompts, and inspect metadata.",
      "commands": {
        "run": {
          "name": "run",
          "help": "Load an agent definition and run it with the given prompt. Accepts a path to a .agent.json file or a bare agent name (resolved from .claudestream/agents/). The definition specifies the model, a prompt template with {variable} placeholders, tool schemas, sandbox policy, and budget constraints. Use --var key=value to substitute template variables. Use --model to override the model declared in the definition.",
          "flags": [
            {
              "name": "var",
              "type": "str",
              "help": "Variable in key=value format (repeatable)",
              "short": null,
